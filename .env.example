REACT_APP_WEBSITE_URL="http://localhost:3000"
REACT_APP_LOCALHOST="localhost"
REACT_APP_FALLBACK_LANGUAGE="en"
REACT_APP_GRAPHQL_API_URL="http://localhost:3001/api/graphql"

# Set this to the API host your local toolkit instance should call.
REACT_APP_API_URL="https://yourserver.io/api/"

# Optional contact email for consumers that expose support/contact UI.
REACT_APP_VILNACRM_GMAIL="support@yourdomain.example"

# Optional footer policy links. Fall back to the VilnaCRM website defaults.
REACT_APP_VILNACRM_PRIVACY_POLICY_URL="https://yourdomain.example/privacy-policy"
REACT_APP_VILNACRM_USAGE_POLICY_URL="https://yourdomain.example/usage-policy"

REACT_APP_STORYBOOK_URL="http://localhost:6006"
MEMLAB_WEBSITE_URL="http://localhost:3000"
